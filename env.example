# Public browser-facing Kratos URL used by client-side Ory code
NEXT_PUBLIC_ORY_SDK_URL=http://localhost:4433

# Server-side Kratos URL used by Next.js server code
ORY_SDK_URL=http://kratos:4433

# Hydra admin URL used for login and consent challenge handling
ORY_HYDRA_ADMIN_URL=http://hydra:4445

# Optional API token for environments that require it
# ORY_PROJECT_API_TOKEN=replace-me
